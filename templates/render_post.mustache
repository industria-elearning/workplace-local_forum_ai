{{!
    @template local_forum_ai/render_post
    Template for rendering a single forum post with indentation and level indicators.

    Example context (json):
    {
      "borderclass": "border-left-primary",
      "marginleft": 30,
      "haslevel": true,
      "levelindicator": "↳ ↳ Reply level 2",
      "subject": "Re: Interesting topic",
      "leveltext": "Level 2",
      "author": "Professor X",
      "created": "2025-11-08 12:45",
      "message": "<p>I agree with your point.</p>"
    }
}}

<div class="mb-3 p-3 border {{borderclass}}"
     style="margin-left: {{marginleft}}px; border-left-width: 4px !important;">
    {{#haslevel}}
        <span class="badge badge-secondary mb-2">
            {{{levelindicator}}}
        </span><br>
    {{/haslevel}}

    <div class="d-flex justify-content-between align-items-start mb-2">
        <strong class="text-primary">{{subject}}</strong>
        <small class="text-muted">{{leveltext}}</small>
    </div>

    <div class="mb-2">
        <em class="text-info">{{author}}</em>
        <small class="text-muted ml-2">({{created}})</small>
    </div>

    <div class="post-content">
        {{{message}}}
    </div>
</div>
