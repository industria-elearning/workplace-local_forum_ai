{{!
    @template local_forum_ai/history_modal
    Template for rendering the AI discussion history inside a modal.

    Example context (json):
    {
      "course": "Mathematics 101",
      "forum": "Debate Forum",
      "discussionlabel": "Discussion: Future of AI",
      "noposts": false,
      "posts": [
        { "html": "<div>Post content rendered separately</div>" }
      ],
      "statusclass": "bg-success text-white",
      "statuslabel": "<i class='fa fa-check mr-2'></i> AI response approved",
      "airesponse": "<p>This is the AI-generated response</p>"
    }
}}

<h4>{{course}} / {{forum}}</h4>
<h5>{{discussionlabel}}</h5>

{{#noposts}}
    <p class="text-warning">{{nopoststext}}</p>
{{/noposts}}

{{^noposts}}
    {{#posts}}
        {{{html}}}
    {{/posts}}
{{/noposts}}

<div class="alert mt-4 {{statusclass}}">
    <h5>{{{statuslabel}}}</h5>
    {{{airesponse}}}
</div>
