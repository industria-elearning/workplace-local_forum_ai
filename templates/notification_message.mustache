{{!
    @template local_forum_ai/notification_message

    Notification message template for AI review feedback

    Example context (json):
    {
        "message": "Grades applied successfully",
        "type": "success",
        "icon": "fa-check-circle"
    }
}}
<div class="alert alert-{{type}} alert-dismissible fade show" role="alert">
    <i class="fa {{icon}}" aria-hidden="true"></i>
    {{{message}}}
    <button type="button" class="close" data-dismiss="alert" aria-label="{{#str}}closebuttontitle, core{{/str}}">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
