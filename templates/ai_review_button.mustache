{{!
    @template local_forum_ai/ai_review_button

    AI Review Button Template

    Template used to render the "Review with AI" button inside the forum grading
    interface. The button is initially hidden and displayed dynamically via JS.

    No context variables required.

    Example context (json):
    {}
}}

<div class="mb-3 fitem">
    <button type="button"
            id="forum-ai-review-btn"
            class="btn btn-primary datacurso-ai-button"
            data-action="local_forum_ai/review_ai">
        <i class="fa fa-magic" aria-hidden="true"></i>
        {{#str}}ai_review_button, local_forum_ai{{/str}}
    </button>
</div>
