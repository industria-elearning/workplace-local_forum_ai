{{!
    @template local_forum_ai/pending_modal
    Template for rendering the pending AI response modal with editable content.

    Example context (json):
    {
      "course": "Mathematics 101",
      "forum": "AI Discussion Forum",
      "discussionlabel": "Discussion: Future of AI",
      "noposts": false,
      "nopoststext": "No posts found.",
      "posts": [
        { "html": "<div>Rendered post 1</div>" },
        { "html": "<div>Rendered post 2</div>" }
      ],
      "airesponseproposed": "AI proposed response",
      "token": "abc123",
      "editmode": true,
      "airesponse": "<p>This is the AI-generated response.</p>",
      "savelabel": "Save",
      "saveapprovelabel": "Save and Approve",
      "rejectlabel": "Reject"
    }
}}

<h4>{{course}} / {{forum}}</h4>
<h5>{{discussionlabel}}</h5>

{{#noposts}}
    <p class="text-warning">{{nopoststext}}</p>
{{/noposts}}

{{^noposts}}
    {{#posts}}
        {{{html}}}
    {{/posts}}
{{/noposts}}

<div class="alert alert-primary mt-4">
    <h5><i class="fa-solid fa-robot"></i> {{airesponseproposed}}</h5>

    <div id="airesponse-content" data-token="{{token}}">
        {{#editmode}}
            <textarea id="airesponse-edit" class="form-control" rows="5">{{{airesponse}}}</textarea>

            <div class="mt-2">
                <button class="btn btn-success btn-sm save-ai" data-token="{{token}}">
                    <i class="fa-solid fa-floppy-disk"></i> {{savelabel}}
                </button>
                <button class="btn btn-primary btn-sm save-approve-ai" data-token="{{token}}">
                    <i class="fa-solid fa-check"></i> {{saveapprovelabel}}
                </button>
                <button class="btn btn-danger btn-sm reject-ai" data-token="{{token}}">
                    <i class="fa-solid fa-times"></i> {{rejectlabel}}
                </button>
            </div>
        {{/editmode}}

        {{^editmode}}
            {{{airesponse}}}
        {{/editmode}}
    </div>
</div>
