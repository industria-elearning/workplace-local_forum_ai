<?xml version="1.0" encoding="UTF-8"?>
<XMLDB PATH="local/forum_ai/db" VERSION="20260507"
    COMMENT="XMLDB file for Moodle local/forum_ai"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
    <TABLES>
        <TABLE NAME="local_forum_ai_config" COMMENT="Forum-specific AI configuration">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" />
                <FIELD NAME="forumid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="tenantid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"
                    DEFAULT="0" />
                <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"
                    SEQUENCE="false" />
                <FIELD NAME="enablediainitconversation" TYPE="int" LENGTH="1" NOTNULL="false"
                    DEFAULT="0" SEQUENCE="false" />
                <FIELD NAME="questionturns" TYPE="int" LENGTH="1" NOTNULL="true"
                    DEFAULT="1" SEQUENCE="false" />
                <FIELD NAME="allowedroles" TYPE="text" LENGTH="1" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="reply_message" TYPE="text" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="require_approval" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"
                    SEQUENCE="false" COMMENT="1 = requiere aprobación, 0 = publicar directo" />
                <FIELD NAME="graderid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="usedelay" TYPE="int" LENGTH="1" NOTNULL="false" DEFAULT="0"
                    SEQUENCE="false" />
                <FIELD NAME="delayminutes" TYPE="int" LENGTH="6" NOTNULL="false" DEFAULT="0"
                    SEQUENCE="false" />
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id" />
                <KEY NAME="forum_tenant_unique" TYPE="unique" FIELDS="forumid, tenantid" />
            </KEYS>
        </TABLE>

        <TABLE NAME="local_forum_ai_pending" COMMENT="Pending AI responses awaiting approval">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" />
                <FIELD NAME="discussionid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="forumid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="parentpostid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="creator_userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="subject" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="message" TYPE="text" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="grade" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending"
                    SEQUENCE="false" />
                <FIELD NAME="approval_token" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="approved_at" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" />
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id" />
                <KEY NAME="approval_token_unique" TYPE="unique" FIELDS="approval_token" />
            </KEYS>
        </TABLE>

        <TABLE NAME="local_forum_ai_queue" COMMENT="Queue for AI forum tasks">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" />
                <FIELD NAME="type" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="itemid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="tenantid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" />
                <FIELD NAME="payload" TYPE="text" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="timetoprocess" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" />
                <FIELD NAME="processed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"
                    SEQUENCE="false" />
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id" />
            </KEYS>
        </TABLE>

    </TABLES>
</XMLDB>
